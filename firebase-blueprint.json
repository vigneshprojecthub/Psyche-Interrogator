{
  "entities": {
    "Session": {
      "title": "Session",
      "description": "A psychological interrogation session",
      "type": "object",
      "properties": {
        "userName": {
          "type": "string",
          "description": "Name of the subject"
        },
        "startTime": {
          "type": "string",
          "format": "date-time",
          "description": "When the session started"
        },
        "endTime": {
          "type": "string",
          "format": "date-time",
          "description": "When the session ended"
        },
        "status": {
          "type": "string",
          "enum": ["active", "completed"],
          "description": "Current status of the session"
        }
      },
      "required": ["userName", "startTime", "status"]
    },
    "Response": {
      "title": "Response",
      "description": "A subject's response to an interrogation question",
      "type": "object",
      "properties": {
        "questionId": {
          "type": "string",
          "description": "ID of the question"
        },
        "questionText": {
          "type": "string",
          "description": "The text of the question asked"
        },
        "answer": {
          "type": "string",
          "description": "The subject's confession"
        },
        "isFollowUp": {
          "type": "boolean",
          "description": "Whether this was an AI-generated follow-up"
        },
        "timeToFirstType": {
          "type": "number",
          "description": "Latency before first keystroke in ms"
        },
        "totalTime": {
          "type": "number",
          "description": "Total time spent answering in ms"
        },
        "answerEditsCount": {
          "type": "number",
          "description": "Number of times the answer was edited"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "When the response was submitted"
        }
      },
      "required": ["questionId", "questionText", "answer", "timestamp"]
    }
  },
  "firestore": {
    "/sessions/{sessionId}": {
      "schema": "Session",
      "description": "Root session documents"
    },
    "/sessions/{sessionId}/responses/{responseId}": {
      "schema": "Response",
      "description": "Individual responses within a session"
    },
    "/analysis/{analysisId}": {
      "schema": "PsychologicalProfile",
      "description": "Final psychological profiles generated for sessions"
    }
  }
}
