rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Public access for the "free" interrogation flow
    // In a production app, you'd want to secure this with session tokens or similar
    
    match /sessions/{sessionId} {
      allow read, create, update: if true;

      match /responses/{responseId} {
        allow read, create: if true;
      }
    }

    match /analysis/{analysisId} {
      allow read, create: if true;
    }

    match /users/{userId} {
      allow read, write: if false; // Auth-based users disabled
    }
  }
}
